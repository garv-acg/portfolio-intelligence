<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.aidan.newsletteragent.overnight</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>cd /Users/aidangarver/Downloads/newsletter_agent &amp;&amp; source app/.venv/bin/activate &amp;&amp; python overnight_runner.py</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>6</integer>
      <key>Minute</key>
      <integer>30</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/aidangarver/Downloads/newsletter_agent/logs/launchd_stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/aidangarver/Downloads/newsletter_agent/logs/launchd_stderr.log</string>

    <key>RunAtLoad</key>
    <false/>
  </dict>
</plist>
