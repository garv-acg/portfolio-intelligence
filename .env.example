# Copy this file to .env and fill in values as needed.
# V1 works without OpenAI/Resend keys by using deterministic fallback summaries.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: NewsAPI key from https://newsapi.org
NEWSAPI_KEY=

# Optional: Resend email delivery from https://resend.com
RESEND_API_KEY=
EMAIL_FROM=Market Brief <onboarding@resend.dev>
EMAIL_TO=your_email@example.com

# Newsletter settings
NEWSLETTER_MAX_ARTICLES_PER_TICKER=3
NEWSLETTER_LOOKBACK_HOURS=24
