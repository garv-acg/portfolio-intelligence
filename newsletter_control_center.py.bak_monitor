def init_state() -> None:
    defaults = {
        "portfolio_path": str(find_portfolio_file()),
        "last_action_output": "",
        "last_action_ok": None,
        "active_page": "Overview",
    }

    for key, value in defaults.items():
        if key not in st.session_state:
            st.session_state[key] = value


def find_portfolio_file() -> Path:
    candidates = [
        Path("portfolio.csv"),
        Path("data/portfolio.csv"),
        Path("app/config/portfolio.csv"),
        Path("app/data/portfolio.csv"),
    ]

    for path in candidates:
        if path.exists():
            return path

    return DEFAULT_PORTFOLIO_PATH


def normalize_portfolio(df: pd.DataFrame) -> pd.DataFrame:
    df = df.copy()
    lower_map = {col.lower().strip(): col for col in df.columns}

    if "ticker" not in lower_map:
        df["ticker"] = ""
    else:
        df = df.rename(columns={lower_map["ticker"]: "ticker"})

    if "shares" not in lower_map:
        df["shares"] = 0.0
    else:
        df = df.rename(columns={lower_map["shares"]: "shares"})

    current_lower_cols = [c.lower().strip() for c in df.columns]

    if "name" not in current_lower_cols:
        df["name"] = ""
    else:
        name_col = next(c for c in df.columns if c.lower().strip() == "name")
        if name_col != "name":
            df = df.rename(columns={name_col: "name"})

    if "cost_basis" not in [c.lower().strip() for c in df.columns]:
        df["cost_basis"] = ""
    else:
        cost_col = next(c for c in df.columns if c.lower().strip() == "cost_basis")
        if cost_col != "cost_basis":
            df = df.rename(columns={cost_col: "cost_basis"})

    df["ticker"] = df["ticker"].astype(str).str.upper().str.strip()
    df["shares"] = pd.to_numeric(df["shares"], errors="coerce").fillna(0.0)
    df["name"] = df["name"].fillna("").astype("string")
    df["cost_basis"] = df["cost_basis"].fillna("").astype("string")

    preferred = ["ticker", "shares", "name", "cost_basis"]
    remaining = [col for col in df.columns if col not in preferred]

    return df[preferred + remaining]


def load_portfolio(path: Path) -> pd.DataFrame:
    if not path.exists():
        return pd.DataFrame(columns=["ticker", "shares", "name", "cost_basis"])
    return normalize_portfolio(pd.read_csv(path))


def save_portfolio(path: Path, df: pd.DataFrame) -> None:
    df = normalize_portfolio(df)
    df = df[df["ticker"].astype(str).str.strip() != ""]
    df.to_csv(path, index=False)


def run_command(command: list[str]) -> tuple[bool, str]:
    try:
        result = subprocess.run(
            command,
            cwd=Path.cwd(),
            capture_output=True,
            text=True,
            check=False,
        )

        output = ""
        if result.stdout:
            output += result.stdout
        if result.stderr:
            output += "\n" + result.stderr

        return result.returncode == 0, output.strip()

    except Exception as exc:
        return False, str(exc)


def try_load_visual_analytics(df: pd.DataFrame) -> dict[str, Any] | None:
    try:
        from app.config.portfolio import load_portfolio
        from app.config.settings import settings
        from app.data.market_data import get_equity_snapshot
        from app.data.visual_analytics import build_visual_analytics

        holdings = load_portfolio(settings.portfolio_file)
        snapshot = get_equity_snapshot(holdings)
        analytics = build_visual_analytics(holdings, snapshot, lookback_days=120)

        return analytics.__dict__

    except Exception:
        return None


def _pretty_column_name(col: str) -> str:
    mapping = {
        "ticker": "Ticker",
        "sector": "Sector",
        "signal_label": "Signal Label",
        "composite_score": "Composite Score (0-100)",
        "volatility_21d_pct": "21D Volatility (%)",
        "relative_strength_21d_pct": "21D Relative Strength (%)",
        "drawdown_pct": "Drawdown (%)",
        "current_weight_pct": "Current Weight (%)",
        "target_weight_pct": "Target Weight (%)",
        "weight_drift_pct": "Weight Drift (%)",
        "value": "Current Value ($)",
        "target_value": "Target Value ($)",
        "trade_value": "Trade Value ($)",
        "action": "Action",
        "cumulative_daily_pl": "Cumulative Daily P/L ($)",
        "avg_contribution_pct": "Avg Contribution (%)",
        "cumulative_contribution_pct": "Cumulative Contribution (%)",
        "avg_move_pct": "Avg Move (%)",
        "avg_weight_pct": "Avg Weight (%)",
        "best_daily_pl": "Best Daily P/L ($)",
        "worst_daily_pl": "Worst Daily P/L ($)",
        "observations": "Observations",
        "daily_pl": "Daily P/L ($)",
        "move_pct": "Move (%)",
        "contribution_pct": "Contribution (%)",
        "portfolio_value": "Portfolio Value ($)",
        "risk_score": "Risk Score (0-100)",
        "inflation_score": "Inflation Score (0-100)",
        "growth_score": "Growth Score (0-100)",
        "liquidity_score": "Liquidity Score (0-100)",
    }
    return mapping.get(str(col), str(col).replace("_", " ").title())


def _format_table_for_display(df):
    import pandas as pd

    if df is None or df.empty:
        return df

    out = df.copy()

    for col in out.columns:
        label = str(col).lower()

        def fmt(v):
            if pd.isna(v):
                return ""
            if isinstance(v, (int, float)):
                if "score" in label:
                    return f"{v:.1f}/100"
                if "pct" in label or "weight" in label or "move" in label or "drawdown" in label or "volatility" in label or "contribution" in label:
                    return f"{v:+.2f}%"
                if "value" in label or "pl" in label or "trade" in label or "price" in label:
                    return f"${v:,.2f}"
                return f"{v:,.2f}"
            return v

        out[col] = out[col].map(fmt)

    out = out.rename(columns={col: _pretty_column_name(col) for col in out.columns})
    return out


def _format_chart_for_display(df):
    if df is None or df.empty:
        return df
    return df.rename(columns={col: _pretty_column_name(col) for col in df.columns})

