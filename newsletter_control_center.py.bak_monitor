def render_sidebar() -> str:
    st.sidebar.markdown("## Control Center")
    st.sidebar.caption("Navigate your workflow from one interface.")

    nav_pages = [
        "Overview",
        "Portfolio",
        "Construction",
        "Backtesting",
        "Execution",
        "Analytics",
        "Newsletter",
        "Preview",
        "Files",
        "History",
        "Factors",
        "Alerts",
    ]

    active_page = st.session_state.get("active_page", "Overview")

    if active_page not in nav_pages:
        active_page = "Overview"
        st.session_state["active_page"] = active_page

    page = st.sidebar.radio(
        "Navigation",
        nav_pages,
        index=nav_pages.index(active_page),
    )

    st.session_state["active_page"] = page

    st.sidebar.divider()
    st.sidebar.markdown("### Settings")

    st.session_state["portfolio_path"] = st.sidebar.text_input(
        "Portfolio CSV path",
        value=st.session_state.get("portfolio_path", str(find_portfolio_file())),
    )

    st.sidebar.divider()
    st.sidebar.markdown("### System")
    st.sidebar.markdown(f'<div class="nav-note">HTML: <code>{NEWSLETTER_HTML_PATH}</code></div>', unsafe_allow_html=True)
    st.sidebar.markdown(f'<div class="nav-note">Text: <code>{NEWSLETTER_TEXT_PATH}</code></div>', unsafe_allow_html=True)

    return page


def render_overview(df: pd.DataFrame, portfolio_path: Path) -> None:
    st.markdown("### Platform Overview")

    c1, c2, c3, c4 = st.columns(4)

    with c1:
        st.metric("Holdings", len(df[df["ticker"].astype(str).str.strip() != ""]))

    with c2:
        total_shares = pd.to_numeric(df["shares"], errors="coerce").fillna(0).sum() if "shares" in df else 0
        st.metric("Total Shares", f"{total_shares:,.3f}")

    with c3:
        st.metric("Newsletter Exists", "Yes" if NEWSLETTER_HTML_PATH.exists() else "No")

    with c4:
        size = NEWSLETTER_HTML_PATH.stat().st_size if NEWSLETTER_HTML_PATH.exists() else 0
        st.metric("HTML Size", f"{size:,.0f} bytes")

    st.divider()

    left, right = st.columns([1.15, 0.85])

    with left:
        st.markdown('<div class="card"><div class="section-title">Current Holdings</div>', unsafe_allow_html=True)
        st.dataframe(df, use_container_width=True, hide_index=True)
        st.markdown("</div>", unsafe_allow_html=True)

    with right:
        st.markdown(
            f"""
            <div class="card">
                <div class="section-title">Workflow</div>
                <div class="muted">
                    1. Edit holdings in Portfolio<br>
                    2. Generate the newsletter<br>
                    3. Preview the HTML<br>
                    4. Send the email to yourself
                </div>
                <br>
                <div class="section-title">Active File</div>
                <div class="muted"><code>{portfolio_path}</code></div>
            </div>
            """,
            unsafe_allow_html=True,
        )


def render_portfolio(df: pd.DataFrame, portfolio_path: Path) -> None:
    st.markdown("### Portfolio Editor")
    st.caption("Edit holdings directly. Save writes back to your portfolio CSV.")

    edited = st.data_editor(
        df,
        num_rows="dynamic",
        use_container_width=True,
        column_config={
            "ticker": st.column_config.TextColumn("Ticker", help="Stock ticker symbol", required=True),
            "shares": st.column_config.NumberColumn(
                "Shares",
                help="Number of shares owned",
                min_value=0.0,
                step=0.001,
                format="%.6f",
                required=True,
            ),
            "name": st.column_config.TextColumn("Company Name"),
            "cost_basis": st.column_config.TextColumn("Cost Basis"),
        },
        hide_index=True,
        key="portfolio_editor",
    )

    c1, c2, c3 = st.columns([1, 1, 2])

    with c1:
        if st.button("Save Portfolio", type="primary", use_container_width=True):
            save_portfolio(portfolio_path, edited)
            st.success(f"Saved portfolio to {portfolio_path}")

    with c2:
        if st.button("Reload Portfolio", use_container_width=True):
            st.rerun()

    with c3:
        st.info("After saving, generate the newsletter from the Newsletter page.")


def render_analytics(df: pd.DataFrame) -> None:
    st.markdown("### Portfolio Analytics")
    st.caption("In-app dashboard view. Newsletter visuals remain in the HTML brief.")

    analytics = try_load_visual_analytics(df)

    if not analytics:
        st.warning("Analytics could not be loaded. Generate the newsletter or check data dependencies.")
        return

    allocation = pd.DataFrame(analytics.get("allocation", []))
    sectors = pd.DataFrame(analytics.get("sector_exposure", []))
    attribution = pd.DataFrame(analytics.get("daily_attribution", []))
    rolling = pd.DataFrame(analytics.get("rolling_returns", []))
    drawdown = pd.DataFrame(analytics.get("drawdown", []))
    vol = analytics.get("volatility_monitor", {}) or {}

    c1, c2, c3, c4 = st.columns(4)

    with c1:
        st.metric("Latest Return", f"{vol.get('latest_daily_return_pct', 0):+.2f}%")

    with c2:
        st.metric("Annualized Vol", f"{vol.get('annualized_volatility_pct', 0):+.2f}%")

    with c3:
        st.metric("21D Realized Vol", f"{vol.get('realized_21d_volatility_pct', 0):+.2f}%")

    with c4:
        st.metric("Vol Status", str(vol.get("status", "N/A")))

    st.divider()

    left, right = st.columns(2)

    with left:
        st.markdown("#### Portfolio Equity Curve")
        if not rolling.empty and "date" in rolling and "portfolio_value" in rolling:
            st.line_chart(rolling.set_index("date")["portfolio_value"], height=260)
        else:
            st.info("No rolling return data available.")

    with right:
        st.markdown("#### Drawdown Monitor")
        if not drawdown.empty and "date" in drawdown and "drawdown_pct" in drawdown:
            st.area_chart(drawdown.set_index("date")["drawdown_pct"], height=260)
        else:
            st.info("No drawdown data available.")

    left, right = st.columns(2)

    with left:
        st.markdown("#### Allocation")
        if not allocation.empty and "ticker" in allocation and "weight_pct" in allocation:
            st.bar_chart(allocation.set_index("ticker")["weight_pct"], height=300)
            st.dataframe(allocation, use_container_width=True, hide_index=True)
        else:
            st.info("No allocation data available.")

    with right:
        st.markdown("#### Sector Exposure")
        if not sectors.empty and "sector" in sectors and "weight_pct" in sectors:
            st.bar_chart(sectors.set_index("sector")["weight_pct"], height=300)
            st.dataframe(_format_table_for_display(sectors), use_container_width=True, hide_index=True)
        else:
            st.info("No sector data available.")

    st.markdown("#### Daily Attribution")
    if not attribution.empty:
        st.dataframe(
            attribution.style.background_gradient(
                subset=["daily_pl", "contribution_pct"],
                cmap="RdYlGn",
            ),
            use_container_width=True,
            hide_index=True,
        )
    else:
        st.info("No attribution data available.")


def render_newsletter_actions() -> None:
    st.markdown("### Newsletter Actions")

    c1, c2, c3 = st.columns(3)

    with c1:
        if st.button("Generate Newsletter", type="primary", use_container_width=True):
            with st.spinner("Generating latest newsletter..."):
                ok, output = run_command([sys.executable, "main.py"])

            st.session_state["last_action_ok"] = ok
            st.session_state["last_action_output"] = output

            if ok:
                st.success("Newsletter generated successfully.")
            else:
                st.error("Newsletter generation failed.")

    with c2:
        if st.button("Send Email", use_container_width=True):
            if not Path("send_newsletter.py").exists():
                st.error("send_newsletter.py not found in project root.")
            else:
                with st.spinner("Sending newsletter email..."):
                    ok, output = run_command([sys.executable, "send_newsletter.py"])

                st.session_state["last_action_ok"] = ok
                st.session_state["last_action_output"] = output

                if ok:
                    st.success("Newsletter email sent successfully.")
                else:
                    st.error("Email send failed.")

    with c3:
        if st.button("Generate + Send", use_container_width=True):
            with st.spinner("Generating newsletter..."):
                ok_generate, output_generate = run_command([sys.executable, "main.py"])

            if not ok_generate:
                st.session_state["last_action_ok"] = False
                st.session_state["last_action_output"] = output_generate
                st.error("Generation failed. Email not sent.")
            elif not Path("send_newsletter.py").exists():
                st.error("send_newsletter.py not found in project root.")
            else:
                with st.spinner("Sending email..."):
                    ok_send, output_send = run_command([sys.executable, "send_newsletter.py"])

                st.session_state["last_action_ok"] = ok_send
                st.session_state["last_action_output"] = output_send

                if ok_send:
                    st.success("Generated and sent successfully.")
                else:
                    st.error("Generated, but email failed.")

    st.divider()

    status_rows = [
        {
            "file": str(NEWSLETTER_HTML_PATH),
            "exists": NEWSLETTER_HTML_PATH.exists(),
            "size_bytes": NEWSLETTER_HTML_PATH.stat().st_size if NEWSLETTER_HTML_PATH.exists() else 0,
        },
        {
            "file": str(NEWSLETTER_TEXT_PATH),
            "exists": NEWSLETTER_TEXT_PATH.exists(),
            "size_bytes": NEWSLETTER_TEXT_PATH.stat().st_size if NEWSLETTER_TEXT_PATH.exists() else 0,
        },
    ]

    st.dataframe(pd.DataFrame(status_rows), use_container_width=True, hide_index=True)

    with st.expander("Last Command Output", expanded=st.session_state.get("last_action_ok") is False):
        st.code(st.session_state.get("last_action_output", "") or "No output yet.")


def render_preview() -> None:
    st.markdown("### HTML Preview")

    if NEWSLETTER_HTML_PATH.exists():
        html = NEWSLETTER_HTML_PATH.read_text(encoding="utf-8", errors="ignore")
        st.components.v1.html(html, height=920, scrolling=True)

        st.download_button(
            "Download HTML",
            data=html,
            file_name="latest_newsletter.html",
            mime="text/html",
            use_container_width=True,
        )
    else:
        st.warning("No HTML newsletter found yet. Generate the newsletter first.")


def render_files(portfolio_path: Path) -> None:
    st.markdown("### Files / CSV")

    st.markdown("#### Portfolio CSV")
    if portfolio_path.exists():
        st.code(portfolio_path.read_text(), language="csv")
    else:
        st.warning("Portfolio file does not exist yet. Save once to create it.")

    st.divider()
    st.markdown("#### Text Newsletter")

    if NEWSLETTER_TEXT_PATH.exists():
        st.text_area(
            "latest_newsletter.txt",
            value=NEWSLETTER_TEXT_PATH.read_text(encoding="utf-8", errors="ignore"),
            height=500,
        )
    else:
        st.warning("No text newsletter found yet.")


def render_factors() -> None:
    st.markdown("### Cumulative Attribution + Factor Engine")
    st.caption("Attribution comes from SQLite history. Factor scores use price history, benchmark relative strength, earnings dates, and SEC flags.")

    st.markdown("#### Cumulative Attribution")

    window = st.selectbox("Attribution window", ["All history", "7 days", "30 days", "90 days"], index=0)

    days = None
    if window == "7 days":
        days = 7
    elif window == "30 days":
        days = 30
    elif window == "90 days":
        days = 90

    attr = cumulative_attribution(days=days)

    if attr.empty:
        st.warning("No attribution history found yet. Generate a few newsletters to build attribution history.")
    else:
        c1, c2, c3 = st.columns(3)
        with c1:
            best = attr.iloc[0]
            st.metric("Top Creator", best["ticker"], f"${best['cumulative_daily_pl']:,.2f}")
        with c2:
            worst = attr.sort_values("cumulative_daily_pl").iloc[0]
            st.metric("Top Destroyer", worst["ticker"], f"${worst['cumulative_daily_pl']:,.2f}")
        with c3:
            st.metric("Tracked Holdings", len(attr))

        st.bar_chart(attr.set_index("ticker")[["cumulative_daily_pl"]].rename(columns={"cumulative_daily_pl": "Cumulative Daily P/L ($)"}), height=320)
        st.dataframe(_format_table_for_display(attr), use_container_width=True, hide_index=True)

    st.divider()
    st.markdown("#### Current Factor Signals")

    try:
        from app.config.portfolio import load_portfolio
        from app.config.settings import settings
        from app.data.earnings import get_upcoming_earnings
        from app.data.sec_filings import get_sec_filings

        holdings = load_portfolio(settings.portfolio_file)
        tickers = [holding.ticker for holding in holdings]

        earnings = get_upcoming_earnings(tickers, days_ahead=30)
        sec = get_sec_filings(tickers, lookback_days=30, max_filings_per_ticker=3)

        signals = build_factor_signals(tickers, earnings_calendar=earnings, sec_filings=sec)
        factor_df = pd.DataFrame([signal.__dict__ for signal in signals])

        if factor_df.empty:
            st.warning("No factor signals generated.")
        else:
            st.bar_chart(factor_df.set_index("ticker")[["composite_score"]].rename(columns={"composite_score": "Composite Score (0-100)"}), height=320)
            st.dataframe(_format_table_for_display(factor_df), use_container_width=True, hide_index=True)

    except Exception as exc:
        st.error(f"Factor engine failed: {exc}")

def render_alerts() -> None:
    st.markdown("### Alert Engine")
    st.caption("Alerts are generated from drawdowns, SEC Item 5.02 filings, earnings proximity, regime shifts, and large position moves.")

    summary = alert_summary()
    c1, c2, c3, c4 = st.columns(4)
    with c1:
        st.metric("Total Alerts", summary.get("total_alerts", 0))
    with c2:
        st.metric("Unresolved", summary.get("unresolved_alerts", 0))
    with c3:
        st.metric("High Severity", summary.get("high_severity_alerts", 0))
    with c4:
        st.metric("Latest Alert", summary.get("latest_alert_at") or "N/A")

    st.divider()
    unresolved_only = st.toggle("Show unresolved only", value=False)
    alerts = pd.DataFrame(latest_alerts(limit=250, unresolved_only=unresolved_only))

    if alerts.empty:
        st.warning("No alerts have been generated yet. Run the newsletter once after installing the alert engine.")
        return

    st.dataframe(_format_table_for_display(alerts), use_container_width=True, hide_index=True)

    st.divider()
    st.markdown("#### Alert Counts by Type")
    if "alert_type" in alerts.columns:
        counts = alerts.groupby("alert_type").size().reset_index(name="count")
        st.bar_chart(counts.set_index("alert_type")["count"], height=320)

def render_construction() -> None:
    st.markdown("### Portfolio Construction Engine")
    st.caption("Signal-driven target allocation with volatility scaling, position caps, sector caps, and rebalance suggestions.")

    try:
        from app.config.portfolio import load_portfolio
        from app.config.settings import settings
        from app.data.market_data import get_equity_snapshot
        from app.data.earnings import get_upcoming_earnings
        from app.data.sec_filings import get_sec_filings
        from app.data.factor_engine import build_factor_signals
        from app.data.portfolio_construction import build_portfolio_construction, ConstructionConfig

        holdings = load_portfolio(settings.portfolio_file)
        tickers = [holding.ticker for holding in holdings]

        snapshot_raw = get_equity_snapshot(holdings)
        snapshot = [item.__dict__ if hasattr(item, "__dict__") else item for item in snapshot_raw]

        earnings = get_upcoming_earnings(tickers, days_ahead=30)
        sec = get_sec_filings(tickers, lookback_days=30, max_filings_per_ticker=3)
        factors = build_factor_signals(tickers, earnings_calendar=earnings, sec_filings=sec)
        factor_dicts = [item.__dict__ for item in factors]

        st.markdown("#### Construction Settings")
        c1, c2, c3, c4 = st.columns(4)

        with c1:
            max_pos = st.slider("Max Position Weight", 5, 40, 22, 1) / 100.0

        with c2:
            max_sector = st.slider("Max Sector Weight", 20, 70, 40, 1) / 100.0

        with c3:
            min_pos = st.slider("Min Position Weight", 0, 10, 2, 1) / 100.0

        with c4:
            rebalance_threshold = st.slider("Rebalance Threshold", 1, 10, 3, 1) / 100.0

        config = ConstructionConfig(
            max_position_weight=max_pos,
            max_sector_weight=max_sector,
            min_position_weight=min_pos,
            rebalance_threshold=rebalance_threshold,
        )

        construction = build_portfolio_construction(snapshot, factor_dicts, config=config)

        if construction.get("status") != "Ready":
            st.warning(construction.get("message", "Portfolio construction unavailable."))
            return

        summary = construction.get("summary", {})

        st.divider()
        st.markdown("#### Construction Summary")

        m1, m2, m3, m4 = st.columns(4)

        with m1:
            st.metric("Portfolio Value", f"${summary.get('portfolio_value', 0):,.2f}")

        with m2:
            st.metric("Rebalance Trades", summary.get("rebalance_trades", 0))

        with m3:
            st.metric("Est. Portfolio Vol", f"{summary.get('estimated_portfolio_volatility_pct', 0):.2f}%")

        with m4:
            st.metric("Turnover", f"{summary.get('turnover_pct', 0):.2f}%")

        targets = pd.DataFrame(construction.get("targets", []))
        trades = pd.DataFrame(construction.get("trades", []))
        sectors = pd.DataFrame(construction.get("sector_targets", []))

        st.divider()
        st.markdown("#### Current vs Target Weights")

        if not targets.empty:
            chart_df = targets[["ticker", "current_weight_pct", "target_weight_pct"]].set_index("ticker")
            st.bar_chart(_format_chart_for_display(chart_df), height=340)
            st.dataframe(_format_table_for_display(targets), use_container_width=True, hide_index=True)
        else:
            st.warning("No target weights generated.")

        st.divider()
        st.markdown("#### Rebalance Suggestions")

        if trades.empty:
            st.success("No rebalance trades exceed the configured threshold.")
        else:
            st.dataframe(_format_table_for_display(trades), use_container_width=True, hide_index=True)

            if st.button("Save Rebalance Recommendations", type="primary"):
                saved_count = save_rebalance_recommendations(construction.get("trades", []))
                st.success(f"Saved {saved_count} pending rebalance recommendation(s) to the execution layer.")

        st.divider()
        st.markdown("#### Sector Constraint View")

        if not sectors.empty:
            sector_chart = sectors[["sector", "current_weight_pct", "target_weight_pct"]].set_index("sector")
            st.bar_chart(_format_chart_for_display(sector_chart), height=320)
            st.dataframe(_format_table_for_display(sectors), use_container_width=True, hide_index=True)

    except Exception as exc:
        st.error(f"Portfolio construction engine failed: {exc}")

def render_execution() -> None:
    st.markdown("### Execution Layer")
    st.caption("Approve or reject rebalance recommendations, maintain a paper trade ledger, track simulated cash, and preserve an execution audit trail.")

    try:
        from app.data.execution_engine import (
            init_execution_tables,
            execution_summary,
            latest_recommendations,
            approve_recommendation,
            reject_recommendation,
            paper_trade_ledger,
            execution_audit_trail,
            set_cash_balance,
        )

        init_execution_tables()
        summary = execution_summary()

        c1, c2, c3, c4 = st.columns(4)
        with c1:
            st.metric("Pending Recommendations", summary.get("pending_recommendations", 0))
        with c2:
            st.metric("Paper Trades", summary.get("paper_trades", 0))
        with c3:
            st.metric("Paper Traded Value", f"${summary.get('total_paper_traded_value', 0):,.2f}")
        with c4:
            st.metric("Simulated Cash", f"${summary.get('cash_balance', 0):,.2f}")

        st.divider()

        with st.expander("Cash Settings", expanded=False):
            new_cash = st.number_input(
                "Set simulated cash balance",
                value=float(summary.get("cash_balance", 0.0)),
                step=100.0,
            )
            if st.button("Update Cash Balance"):
                set_cash_balance(float(new_cash))
                st.success("Cash balance updated.")
                st.rerun()

        st.markdown("#### Pending Rebalance Recommendations")
        pending = pd.DataFrame(latest_recommendations(status="Pending", limit=100))

        if pending.empty:
            st.info("No pending rebalance recommendations. Save recommendations from the Construction page first.")
        else:
            display_cols = [
                "id", "created_at", "ticker", "action", "sector",
                "current_weight_pct", "target_weight_pct", "weight_drift_pct",
                "trade_value", "composite_score", "signal_label"
            ]
            display_cols = [c for c in display_cols if c in pending.columns]
            clean_pending = pending[display_cols].copy()
            clean_pending = clean_pending.rename(columns={
                "id": "Recommendation ID",
                "created_at": "Created At",
                "ticker": "Ticker",
                "action": "Action",
                "sector": "Sector",
                "current_weight_pct": "Current Weight (%)",
                "target_weight_pct": "Target Weight (%)",
                "weight_drift_pct": "Weight Drift (%)",
                "trade_value": "Trade Value ($)",
                "composite_score": "Composite Score (0-100)",
                "signal_label": "Signal Label",
            })

            for col in ["Current Weight (%)", "Target Weight (%)", "Weight Drift (%)"]:
                if col in clean_pending.columns:
                    clean_pending[col] = clean_pending[col].map(lambda x: f"{float(x):+.2f}%")

            if "Trade Value ($)" in clean_pending.columns:
                clean_pending["Trade Value ($)"] = clean_pending["Trade Value ($)"].map(lambda x: f"${float(x):,.2f}")

            if "Composite Score (0-100)" in clean_pending.columns:
                clean_pending["Composite Score (0-100)"] = clean_pending["Composite Score (0-100)"].map(lambda x: f"{float(x):.1f}/100")

            if "Created At" in clean_pending.columns:
                clean_pending["Created At"] = clean_pending["Created At"].astype(str).str.slice(0, 19)

            st.dataframe(clean_pending, use_container_width=True, hide_index=True)

            st.markdown("#### Decision")
            rec_ids = pending["id"].astype(int).tolist()
            selected_id = st.selectbox("Recommendation ID", rec_ids)

            selected_row = pending[pending["id"] == selected_id].iloc[0]
            selected_action = str(selected_row.get("action", "")).upper()
            selected_ticker = selected_row.get("ticker", "")
            selected_trade_value = float(selected_row.get("trade_value", 0) or 0)
            current_cash = float(summary.get("cash_balance", 0.0) or 0.0)

            st.markdown("#### Selected Recommendation")
            s1, s2, s3, s4 = st.columns(4)

            with s1:
                st.metric("Ticker", selected_ticker)

            with s2:
                st.metric("Action", selected_action)

            with s3:
                st.metric("Trade Value", f"${selected_trade_value:,.2f}")

            with s4:
                cash_after = current_cash - abs(selected_trade_value) if selected_action == "BUY" else current_cash + abs(selected_trade_value)
                st.metric("Cash After Approval", f"${cash_after:,.2f}")

            if selected_action == "BUY" and current_cash < abs(selected_trade_value):
                st.warning("This BUY would exceed simulated cash. You can still approve it, but simulated cash will go negative.")

            note = st.text_input("Decision note", value="")
            simulated_price = st.number_input("Optional simulated execution price", min_value=0.0, value=0.0, step=1.0)

            b1, b2 = st.columns(2)
            with b1:
                if st.button("Approve Selected Recommendation", type="primary"):
                    approve_recommendation(
                        int(selected_id),
                        note=note,
                        simulated_price=simulated_price if simulated_price > 0 else None,
                    )
                    st.success(f"Approved recommendation {selected_id}.")
                    st.rerun()

            with b2:
                if st.button("Reject Selected Recommendation"):
                    reject_recommendation(int(selected_id), note=note)
                    st.warning(f"Rejected recommendation {selected_id}.")
                    st.rerun()

        st.divider()

        st.markdown("#### Paper Trade Ledger")
        trades = pd.DataFrame(paper_trade_ledger(limit=250))
        if trades.empty:
            st.info("No paper trades executed yet.")
        else:
            st.dataframe(_format_table_for_display(trades), use_container_width=True, hide_index=True)

        st.divider()

        st.markdown("#### Execution Audit Trail")
        audit = pd.DataFrame(execution_audit_trail(limit=250))
        if audit.empty:
            st.info("No execution audit events yet.")
        else:
            st.dataframe(_format_table_for_display(audit), use_container_width=True, hide_index=True)

    except Exception as exc:
        st.error(f"Execution layer failed: {exc}")

def render_backtesting() -> None:
    st.markdown("### Backtesting Engine V1")
    st.caption("Rolling rebalance simulation with SPY benchmark comparison, transaction costs, Sharpe, Sortino, alpha/beta, turnover, and factor contribution.")

    try:
        from app.config.portfolio import load_portfolio
        from app.config.settings import settings
        from app.data.backtesting_engine import run_backtest, BacktestConfig

        holdings = load_portfolio(settings.portfolio_file)
        tickers = [holding.ticker for holding in holdings]

        st.markdown("#### Backtest Settings")
        c1, c2, c3, c4 = st.columns(4)

        with c1:
            benchmark = st.text_input("Benchmark", value="SPY")
        with c2:
            lookback_days = st.slider("Lookback Days", 90, 365, 180, 15)
        with c3:
            rebalance_frequency = st.slider("Rebalance Frequency (Days)", 5, 63, 21, 1)
        with c4:
            transaction_cost_bps = st.slider("Transaction Cost (bps)", 0, 50, 10, 1)

        initial_capital = st.number_input("Initial Capital ($)", min_value=1000.0, value=10000.0, step=1000.0)

        config = BacktestConfig(
            benchmark=benchmark.upper().strip(),
            lookback_days=int(lookback_days),
            rebalance_frequency_days=int(rebalance_frequency),
            transaction_cost_bps=float(transaction_cost_bps),
            initial_capital=float(initial_capital),
        )

        if st.button("Run Backtest", type="primary"):
            with st.spinner("Running rolling rebalance backtest..."):
                st.session_state["latest_backtest"] = run_backtest(tickers, config=config)

        result = st.session_state.get("latest_backtest")

        if not result:
            st.info("Click Run Backtest to simulate the construction engine historically.")
            return

        if result.get("status") != "Ready":
            st.warning(result.get("message", "Backtest unavailable."))
            return

        metrics = result.get("metrics", {})

        st.divider()
        st.markdown("#### Performance Summary")

        m1, m2, m3, m4 = st.columns(4)
        with m1:
            st.metric("Strategy Return", f"{metrics.get('strategy_total_return_pct', 0):+.2f}%")
        with m2:
            st.metric("Benchmark Return", f"{metrics.get('benchmark_total_return_pct', 0):+.2f}%")
        with m3:
            st.metric("Active Return", f"{metrics.get('active_return_pct', 0):+.2f}%")
        with m4:
            st.metric("Max Drawdown", f"{metrics.get('max_drawdown_pct', 0):+.2f}%")

        r1, r2, r3, r4 = st.columns(4)
        with r1:
            st.metric("Sharpe Ratio", f"{metrics.get('sharpe_ratio', 0):.2f}")
        with r2:
            st.metric("Sortino Ratio", f"{metrics.get('sortino_ratio', 0):.2f}")
        with r3:
            st.metric("Beta to Benchmark", f"{metrics.get('beta_to_benchmark', 0):.2f}")
        with r4:
            st.metric("Annualized Alpha", f"{metrics.get('annualized_alpha_pct', 0):+.2f}%")

        t1, t2, t3 = st.columns(3)
        with t1:
            st.metric("Avg Turnover", f"{metrics.get('avg_turnover_pct', 0):.2f}%")
        with t2:
            st.metric("Transaction Costs", f"${metrics.get('total_transaction_cost_$', 0):,.2f}")
        with t3:
            st.metric("Rebalances", metrics.get("rebalance_count", 0))

        st.divider()

        st.markdown("#### Strategy vs Benchmark")
        equity = pd.DataFrame(result.get("equity_curve", []))
        if not equity.empty:
            chart = equity.set_index("date")[["strategy_value", "benchmark_value"]].rename(columns={
                "strategy_value": "Strategy Value ($)",
                "benchmark_value": "Benchmark Value ($)",
            })
            st.line_chart(chart, height=360)
            st.dataframe(_format_table_for_display(equity), use_container_width=True, hide_index=True)

        st.divider()

        st.markdown("#### Turnover and Transaction Costs")
        turnover = pd.DataFrame(result.get("turnover", []))
        if turnover.empty:
            st.info("No rebalance events occurred in this window.")
        else:
            turnover_chart = turnover.set_index("date")[["turnover_pct"]].rename(columns={"turnover_pct": "Turnover (%)"})
            st.bar_chart(turnover_chart, height=300)
            st.dataframe(_format_table_for_display(turnover), use_container_width=True, hide_index=True)

        st.divider()

        st.markdown("#### Factor Contribution Over Time")
        factor_contribution = pd.DataFrame(result.get("factor_contribution", []))
        if factor_contribution.empty:
            st.info("No factor contribution history generated yet.")
        else:
            factor_chart = factor_contribution.set_index("ticker")[[
                "avg_composite_score",
                "avg_momentum_score",
                "avg_volatility_score",
                "avg_relative_strength_score",
                "avg_drawdown_score",
            ]].rename(columns={
                "avg_composite_score": "Avg Composite Score (0-100)",
                "avg_momentum_score": "Avg Momentum Score (0-100)",
                "avg_volatility_score": "Avg Volatility Score (0-100)",
                "avg_relative_strength_score": "Avg Relative Strength Score (0-100)",
                "avg_drawdown_score": "Avg Drawdown Score (0-100)",
            })
            st.bar_chart(factor_chart, height=360)
            st.dataframe(_format_table_for_display(factor_contribution), use_container_width=True, hide_index=True)

    except Exception as exc:
        st.error(f"Backtesting engine failed: {exc}")

def main() -> None:
    st.set_page_config(
        page_title="Newsletter Control Center",
        page_icon="📊",
        layout="wide",
        initial_sidebar_state="expanded",
    )

    st.markdown(APP_CSS, unsafe_allow_html=True)
    init_state()
    page = render_sidebar()

    portfolio_path = Path(st.session_state["portfolio_path"])
    df = load_portfolio(portfolio_path)

    render_header()
    st.divider()

    if page == "Overview":
        render_overview(df, portfolio_path)
    elif page == "Portfolio":
        render_portfolio(df, portfolio_path)
    elif page == "Construction":
        render_construction()
    elif page == "Backtesting":
        render_backtesting()
    elif page == "Execution":
        render_execution()
    elif page == "Analytics":
        render_analytics(df)
    elif page == "Newsletter":
        render_newsletter_actions()
    elif page == "Preview":
        render_preview()
    elif page == "Files":
        render_files(portfolio_path)
    elif page == "Factors":
        render_factors()
    elif page == "Alerts":
        render_alerts()


if __name__ == "__main__":
    main()
